RewriteEngine On
RewriteBase "/"

# If the request is for an existing file or directory, serve it directly
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# Route /* requests to fcgi 
RewriteCond "%{REQUEST_URI}" !=/test-httpserver.fcgi
RewriteRule "^(.*)" "test-httpserver.fcgi" [L,QSA]

DirectoryIndex test-httpserver.fcgi
